<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	    KeepAwakeHelper (command-line tool) is not sandboxed.
	    It inherits TCC permissions from the parent app bundle.
	    Hardened Runtime is required. The helper is a placeholder
	    kept for build/release flow compatibility.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
